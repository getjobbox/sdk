{
  "name": "getjobbox/sdk",
  "description": "Official JobBox PHP SDK for the partner Jobs API",
  "type": "library",
  "license": "MIT",
  "keywords": ["jobbox", "jobs", "sdk", "api"],
  "homepage": "https://getjobbox.com",
  "support": {
    "source": "https://github.com/getjobbox/sdk/tree/main/php",
    "issues": "https://github.com/getjobbox/sdk/issues"
  },
  "authors": [
    {
      "name": "JobBox",
      "homepage": "https://getjobbox.com"
    }
  ],
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "GetJobBox\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "GetJobBox\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
